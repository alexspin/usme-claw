{
  "id": "usme-claw",
  "name": "USME Context Engine",
  "description": "Utility-Shaped Memory Ecology — relevance-based context assembly (shadow mode via before_prompt_build hook)",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mode": { "type": "string", "enum": ["active", "log-only", "off"], "default": "log-only" },
      "db.host": { "type": "string", "default": "localhost" },
      "db.port": { "type": "integer", "default": 5432 },
      "db.database": { "type": "string", "default": "usme" },
      "db.user": { "type": "string", "default": "usme" },
      "db.password": { "type": "string", "default": "usme_dev" },
      "db.poolMax": { "type": "integer", "default": 10 },
      "embeddingApiKey": { "type": "string", "default": "" }
    }
  }
}
