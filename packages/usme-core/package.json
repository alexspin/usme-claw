{
  "name": "@usme/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate": "node-pg-migrate up --migrations-dir db/migrations --database-url-var DATABASE_URL",
    "migrate:down": "node-pg-migrate down --migrations-dir db/migrations --database-url-var DATABASE_URL"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "destr": "^2.0.5",
    "lru-cache": "^11.0.0",
    "node-cron": "^3.0.0",
    "node-pg-migrate": "^7.0",
    "openai": "^4.0.0",
    "pg": "^8.12",
    "pino": "^9.0.0",
    "tiktoken": "^1.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.0",
    "@types/pg": "^8.11",
    "vitest": "^2.0"
  }
}
