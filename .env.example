# Copy to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# --- Postgres (Docker Compose) ---
POSTGRES_DB=usme
POSTGRES_USER=usme
POSTGRES_PASSWORD=usme_dev
POSTGRES_PORT=5432

# Constructed from the above — used by migrations and the plugin
DATABASE_URL=postgres://usme:usme_dev@localhost:5432/usme

# --- API Keys ---
OPENAI_API_KEY=sk-...          # Required: embeddings (text-embedding-3-small)
ANTHROPIC_API_KEY=sk-ant-...   # Required: extraction (Haiku) + consolidation (Sonnet)
