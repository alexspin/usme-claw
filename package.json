{
  "name": "usme-claw",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:integration": "npm run test:integration --workspaces",
    "db:start": "docker compose up -d db && docker compose wait db",
    "db:stop": "docker compose stop db",
    "db:reset": "docker compose down -v && docker compose up -d db && docker compose wait db && npm run db:migrate",
    "db:migrate": "npm run migrate --workspace=packages/usme-core",
    "db:migrate:test": "DATABASE_URL=postgres://usme:usme_test@localhost:5433/usme_test npm run migrate --workspace=packages/usme-core",
    "migrate": "npm run migrate --workspace=packages/usme-core",
    "migrate:test": "DATABASE_URL=postgres://usme:usme_test@localhost:5433/usme_test npm run migrate --workspace=packages/usme-core"
  },
  "devDependencies": {
    "typescript": "^5.4",
    "vitest": "^2.0"
  },
  "dependencies": {
    "jsonrepair": "^3.13.3"
  }
}
